   "source": [
    "import numpy as np\n",
    "np.random.seed(7)\n",
    "paths = np.random.normal(0.0, 0.01, size=(1000, 12)).cumsum(axis=1)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "vol = paths.std(axis=0)\n",
    "tenor = np.arange(1,13)/12\n",
    "convexity_bp = 0.5 * (vol**2) * tenor * 10000\n",
    "convexity_bp"
   ]
  }
